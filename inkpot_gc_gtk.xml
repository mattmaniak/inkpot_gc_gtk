<?xml version="1.0" encoding="UTF-8"?>

<!--
Gynvael Coldwind's inkpot_gc theme for GVim/Sublime ported to GTK+ editors.
This is only theme, not full config. Based on screenshots from stream.
Some colors were taken directly from inkpot_gc.vim.
Others may be vary with Vim/Sublime original due the optimization for gedit.

Worth seeing:
http://gynvael.coldwind.pl/
https://www.youtube.com/user/GynvaelEN
https://www.youtube.com/user/GynvaelColdwind

Message included in his config:
<quote>
	Vim color file
	Name:       inkpot.vim
	Maintainer: Ciaran McCreesh <ciaran.mccreesh@googlemail.com>
	Homepage:   http://github.com/ciaranm/inkpot/

	This version contains minor color changes by Gynvael Coldwind. You can find
	the original version made by Ciaran at http://github.com/ciaranm/inkpot/
	(check it out, it's great!).
</quote>
-->

<style-scheme id="inkpot_gc_gtk" name="inkpot_gc_gtk" version="1.0">

	<!--Main colors-->
	<color name="black" value="#030303"/>
	<color name="blue" value="#409090"/>
	<color name="bright_purple" value="#9898D2"/>
	<color name="dark_purple" value="#1C1D37"/>
	<color name="grey" value="#404040"/>
	<color name="green" value="#78B99A"/>
	<color name="intense_green" value="#33B441"/>
	<color name="orange" value="#F0AD6D"/>
	<color name="pink" value="#FF8BFF"/>
	<color name="purple" value="#322C55"/>
	<color name="purple_chrome" value="#D0D1F7"/>
	<color name="red" value="#6E2E2E"/>
	<color name="white" value="#FFFFFF"/>
	<color name="yellow" value="#FFFFCD"/>

	<!--Global styles-->
	<style name="background-pattern" background="purple"/>
	<style name="bracket-match" foreground="orange"/>
	<style name="cursor" foreground="green"/>
	<style name="current-line" background="#4C4472"/><!--Light purple.-->
	<style name="line-numbers" foreground="bright_purple" background="purple"/>
	<style name="selection" foreground="white" background="purple"/>
	<style name="search-match" foreground="black" background="orange"/>
	<style name="text" foreground="green" background="dark_purple"/>

	<!--Syntax highlighting-->
	<style name="def:comment" foreground="intense_green"/>
	<style name="def:constant" foreground="orange"/>
	<style name="def:error" foreground="white" background="red"/>
	<style name="def:number" foreground="orange"/>
	<style name="def:preprocessor" foreground="blue"/>
	<style name="def:shebang" foreground="intense_green" bold="true"/>
	<style name="def:special-char" foreground="bright_purple"/>
	<style name="def:statement" foreground="purple_chrome"/>
	<style name="def:string" foreground="orange"/>
	<style name="def:type" foreground="pink"/>

	<!--Diff highlighting-->
	<style name="diff:added-line" foreground="yellow" background="intense_green
	"/><style name="diff:changed-line" foreground="yellow" background="blue"/>
	<style name="diff:removed-line" foreground="yellow" background="red"/>

</style-scheme>

