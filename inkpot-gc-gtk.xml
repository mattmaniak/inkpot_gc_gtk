<style-scheme id="inkpot-gc-gtk" name="inkpot-gc-gtk" version="1.0">
<!--Main colors-->
  <color name="black" value="#030303"/>
  <color name="blue" value="#409090"/>
  <color name="bright_purple" value="#8b8bcd"/>
  <color name="dark_purple" value="#1b1c34"/>
  <color name="grey" value="#404040"/>
  <color name="green" value="#6dcd76"/>
  <color name="intense_green" value="#33b441"/>
  <color name="orange" value="#ffa668"/>
  <color name="pink" value="#f78ef3"/>
  <color name="purple" value="#322c55"/>
  <color name="chrome" value="#d0d1f7"/>
  <color name="red" value="#6e2e2e"/>
  <color name="white" value="#ffffff"/>
  <color name="yellow" value="#ffffcd"/>

  <!--Global styles-->
  <style name="background-pattern" background="purple"/>
  <style name="bracket-match" foreground="orange"/>
  <style name="cursor" foreground="green"/>
  <style name="current-line" background="bright_purple"/>
  <style name="line-numbers" foreground="bright_purple" background="purple"/>
  <style name="selection" foreground="white" background="purple"/>
  <style name="search-match" foreground="black" background="orange"/>
  <style name="text" foreground="green" background="dark_purple"/>
  <style name="right-margin" foreground="bright_purple"
  background="bright_purple"/>

  <!--Syntax highlighting-->
  <style name="def:comment" foreground="intense_green"/>
  <style name="def:constant" foreground="orange"/>
  <style name="def:error" foreground="white" background="red"/>
  <style name="def:number" foreground="orange"/>
  <style name="def:preprocessor" foreground="blue"/>
  <style name="def:shebang" foreground="intense_green" bold="true"/>
  <style name="def:special-char" foreground="bright_purple"/>
  <style name="def:statement" foreground="chrome"/>
  <style name="def:string" foreground="orange"/>
  <style name="def:type" foreground="pink"/>

  <!--Diff highlighting-->
  <style name="diff:added-line" foreground="yellow"
  background="intense_green"/>
  <style name="diff:changed-line" foreground="yellow" background="blue"/>
  <style name="diff:removed-line" foreground="yellow" background="red"/>
</style-scheme>
